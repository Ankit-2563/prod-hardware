#ifndef SECRETS_H
#define SECRETS_H

#define DEVICE_ID "CRUX-001"
#define DEVICE_SECRET "your-long-random-secret-min-16-chars"
#define DEVICE_NAME "your-device-name"
#define FIRMWARE_VER "12.0.0"

#define SERVER_HOST "YOUR.EC2.PUBLIC.IP"
#define SERVER_PORT 443
#define USE_HTTPS true

// Paste your Nginx server.crt between EOF markers (full PEM including BEGIN/END).
#if USE_HTTPS
static const char SERVER_CERT[] PROGMEM = R"EOF(
-----BEGIN CERTIFICATE-----
PASTE_CERTIFICATE_HERE
-----END CERTIFICATE-----
)EOF";
#endif


#define REGISTER_PATH "/api/hardware/register"
#define DATA_PATH "/api/hardware/data"

#endif
